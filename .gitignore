# =============================================================
# Secrets and environment
# =============================================================
.env
.env.local
.env.*.local

# =============================================================
# Python build artifacts and virtual environments
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# =============================================================
# Caches and databases (regenerable; can grow large)
# =============================================================
*.sqlite
*.sqlite3
*.db

# Sentence-BERT embedding cache (Phase 5 Track B; can exceed 100 MB)
data/embeddings_cache.keys.json
data/embeddings_cache.vectors.npy
*.npy
*.npz

# =============================================================
# Pipeline artifacts (regenerable from cache + scripts)
# =============================================================
# Phase 2 — raw model responses (480 files)
data/responses/

# Phase 3 — structured extractions (480 files)
data/extractions/

# Phase 4 — enriched / grounded records (480 files) + summary sidecar
data/enriched/
data/enriched/_summary.json

# Phase 5 Track A + DAGMetric — LLM judge outputs (480 files)
data/judged/

# =============================================================
# Reference data (data/external/)
# =============================================================
# Reference CSVs (BLS prices, USDA Thrifty Plan, Compendium activities)
# are COMMITTED on purpose — they pin the exact snapshot used in the
# paper and are small (<100 KB total). MANIFEST.json carries SHA256s
# for verification. Regenerate via:
#     python -m src.download_external_data [--refresh-bls | --force]
# (No ignore rule needed; this comment is for clarity.)

# =============================================================
# Generated output artifacts (regenerable from src/coverage_report.py
# and src/generate_phase7_figures.py)
# =============================================================
# Use ** so nested splits like results/baseline/ and results/constrained/
# are also caught — the single-* glob does not recurse.
results/**/*.csv
results/figures/

# Phase 6 human ratings + validation manifest are NOT regenerable from
# code (they are hand-entered human data) — explicitly allow them so
# they get committed for paper reproducibility.
!results/validation/
!results/validation/*.csv
!results/validation/*.json

# Dashboard local results sidecar (regenerable)
dashboard/src/data/results.json

# =============================================================
# Node / dashboard build outputs
# =============================================================
node_modules/
dashboard/dist/
dashboard/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================
# OS / editor cruft
# =============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.bak
*.tmp

# =============================================================
# LaTeX build artifacts (paper/main.tex compilation outputs)
# =============================================================
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
paper/*.pdf

# Exception: the progress-report PDF is a final deliverable, not a
# LaTeX build output. It is generated by reportlab from CSVs and we
# commit it so it can be viewed directly on GitHub.
!paper/AccessibleHealthBench_progress_report.pdf

# =============================================================
# Logs
# =============================================================
*.log
logs/

# =============================================================
# Tooling / local-only overrides
# =============================================================
.claude/
*.local.json

# =============================================================
# Archives (if any) — typically large binary files we don't track
# =============================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
