# Secrets / environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Caches / databases
*.sqlite
*.sqlite3
*.db

# Node / dashboard
node_modules/
dashboard/dist/
dashboard/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Pipeline artifacts (regenerable — produced by src/generate.py, src/extract.py,
# and src/ground_all.py respectively; reproducible from cache + scripts)
data/responses/
data/extractions/
data/enriched/

# Note on data/external/:
# Reference CSVs (BLS prices, USDA Thrifty Plan, Compendium activities) are
# COMMITTED on purpose — they pin the exact snapshot used in the paper and are
# small (<100KB total). MANIFEST.json carries SHA256s for verification.
# Regenerate via: python -m src.download_external_data [--refresh-bls | --force]

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
paper/*.pdf

# Generated output artifacts (regenerable from src/coverage_report.py)
# Use ** so nested splits like results/baseline/ and results/constrained/
# are also caught — the single-* glob does not recurse.
results/**/*.csv
results/figures/
dashboard/src/data/results.json

# Phase 4 grounding summary sidecar (regenerable; written by src/ground_all.py)
data/enriched/_summary.json

# Logs
*.log
logs/

# Local-only overrides
.claude/
*.local.json